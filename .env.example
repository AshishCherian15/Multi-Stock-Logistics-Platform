# ─────────────────────────────────────────────────────────────────────────────
# MultiStock Logistics Platform – environment variables
# Copy this file to .env and fill in the real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ───────────────────────────────────────────────────────────────
SECRET_KEY=django-insecure-local-dev-key-change-this-in-production
DEBUG=True

# Extra allowed hosts beyond .vercel.app / .onrender.com (comma-separated)
EXTRA_ALLOWED_HOSTS=

# ── Database ──────────────────────────────────────────────────────────────────
# Local development: leave as SQLite
DATABASE_URL=sqlite:///db.sqlite3

# Supabase PostgreSQL (Transaction Pooler – recommended for serverless/PaaS):
# Find this in: Supabase dashboard → Project Settings → Database → Connection string
# Choose "Transaction pooler" tab, port 6543
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Set this to True when DATABASE_URL points to Supabase (or any remote Postgres)
DB_SSL_REQUIRE=False

# ── CORS / CSRF ───────────────────────────────────────────────────────────────
# Comma-separated list of your Vercel frontend URLs (only needed in production)
CORS_ALLOWED_ORIGINS=
# Same as above, used for CSRF trusted origins
CSRF_TRUSTED_ORIGINS_EXTRA=

# ── Email (leave blank to use console/stdout in development) ──────────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=MultiStock Platform <noreply@multistock.com>

